# ==========================================
# CONFIGURAÇÕES PRINCIPAIS (EDGE NODE)
# ==========================================
ZONE_INFO="America/Fortaleza"
EDGE_API_PORT=8080
LOG_LEVEL="INFO" # INFO, DEBUG, WARNING

# ⚠️ [PREENCHER] Sensível: Defina o token de autenticação compartilhada da API.
EDGE_SHARED_AUTH=

# ==========================================
# COMUNICAÇÃO MQTT
# ==========================================
MQTT_PORT=1883

# ⚠️ [PREENCHER] Sensível: Senha de acesso do dispositivo ao broker MQTT.
MQTT_PASS_DEVICE=

# ⚠️ [PREENCHER] Sensível: Senha de acesso do serviço ao broker MQTT.
MQTT_PASS_SERVICE=

# ==========================================
# RECONHECIMENTO FACIAL E IA
# ==========================================

# ⚠️ [PREENCHER] Sensível: Chave de criptografia dos embeddings faciais.
FACE_EMBEDDING_ENCRYPTION_KEY=

FACE_SCORE_THRESHOLD=0.8
FACE_MATCH_THRESHOLD=0.363

# ==========================================
# FILAS E MEMÓRIA (REDIS)
# ==========================================
MAX_FRAME_QUEUE=100
MAX_EVENTOS_PRESENCA_REDIS=50000

# ==========================================
# INTEGRAÇÃO INTERSCITY
# ==========================================
INTERSCITY_API_URL=https://cidadesinteligentes.lsdi.ufma.br/interscity_lh
RESOURCE_ADAPTOR_PATH=/adaptor/resources
INTERSCITY_QUEUE_MAX=1000
INTERSCITY_WORKERS=1
INTERSCITY_TIMEOUT_SECONDS=5

# ==========================================
# MÉTRICAS E DISPOSITIVO
# ==========================================
METRICAS_AVG_US_PATH=/data/logs/metricas_avg_us.txt
METRICAS_AVG_US_AMOSTRAS_PATH=/data/logs/metricas_avg_us_amostras.csv
TCC_EVIDENCIAS_ENABLED=1
TCC_EVIDENCIAS_DIR=/data/logs/tcc

# ⚠️ [PREENCHER] Defina o código de identificação do dispositivo para as métricas, se tiver.
METRICAS_AVG_US_DISPOSITIVO_CODIGO=

# ==========================================
# INTEGRAÇÃO COM O SERVIDOR DE PRODUÇÃO
# ==========================================
# ⚠️ [MUDAR NA COMUNICAÇÃO COM PROD]
# Descomente e preencha as variáveis abaixo quando este nó 
# for interagir com o ambiente de produção do Autoponto.

NODE_UUID=
AUTOPONTO_API_URL=
AUTOPONTO_API_TOKEN=
